{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Prepare debug target",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "debug",
                "--target",
                "${command:cmake.launchTargetName}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        }
    ]
}
